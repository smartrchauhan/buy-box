# Template only. Real PROD values are never stored in a file — DB credentials and API keys
# live in AWS Secrets Manager (see infra/, Phase 4). This file only documents which
# non-secret config values the app expects at runtime in PROD.
BUYBOX_ENV=prod

AWS_REGION=us-east-1

# Populated by CDK output / Secrets Manager at deploy time, not committed here.
DATABASE_SECRET_ARN=
OFFERS_QUEUE_URL=
